# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# `react-native-textflow` uses SwiftUI's Layout protocol (iOS 16+).
# `min_ios_version_supported` is the RN-default minimum (currently 15.1);
# we take the higher of the two so the example always satisfies our pod.
platform :ios, [Gem::Version.new('16.0'), Gem::Version.new(min_ios_version_supported)].max.to_s
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'AdaptiveTextExample' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # XCTest unit-test bundle for the library. The target itself is
  # created by `scripts/add_test_target.rb` (idempotent — see comment
  # at the top of that file). We declare it here so CocoaPods links
  # the same pods the host app links into the test bundle, which is
  # what `BUNDLE_LOADER`/`TEST_HOST` expect at runtime when XCTest
  # injects the bundle into a launched copy of `AdaptiveTextExample`.
  #
  # We rely on `inherit! :search_paths` rather than re-linking every
  # transitive pod — the test bundle does not produce its own binary
  # copy of e.g. React, it just needs the headers at compile time;
  # the actual symbols are resolved at runtime through the host app.
  target 'AdaptiveTextExampleTests' do
    inherit! :search_paths
  end

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
  end
end
