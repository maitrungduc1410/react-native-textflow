<?xml version="1.0" encoding="utf-8"?>
<!--
  Test-only manifest for `androidTest`. Registers an empty
  `androidx.activity.ComponentActivity` so `ActivityScenario.launch(...)`
  has something to launch when our Compose UI test mounts AdaptiveTextView
  inside a real window. The host app's manifest does not need to know about
  this — it is merged only into the test APK.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <application>
    <activity
        android:name="androidx.activity.ComponentActivity"
        android:exported="true" />
  </application>
</manifest>
